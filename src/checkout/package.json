{
  "name": "checkout-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "serve": "nest start",
    "serve:dev": "nest start --watch",
    "serve:debug": "nest start --debug --watch",
    "serve:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:integration": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.4",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.4",
    "@nestjs/platform-express": "^11.1.4",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/terminus": "^11.0.1",
    "@opentelemetry/auto-instrumentations-node": "^0.61.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.204.0",
    "@opentelemetry/id-generator-aws-xray": "^2.1.0",
    "@opentelemetry/resource-detector-aws": "^2.3.0",
    "@opentelemetry/sdk-node": "^0.204.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.2",
    "class-validator": "^0.14.3",
    "nestjs-otel": "^7.1.0",
    "prom-client": "^15.2.0",
    "redis": "^5.6.0",
    "reflect-metadata": "^0.2.0",
    "axios": "^1.7.9",
    "rimraf": "^6.1.0",
    "rxjs": "^7.9.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.1.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.4",
    "@types/express": "^5.0.4",
    "@types/jest": "30.1.0",
    "@types/node": "^24.2.0",
    "@types/supertest": "^6.1.0",
    "@types/redis": "^4.1.0",
    "eslint": "^9.40.0",
    "nock": "^14.0.0",
    "redis-memory-server": "^0.11.0",
    "eslint-config-prettier": "^10.2.0",
    "eslint-plugin-prettier": "^5.6.0",
    "jest": "30.1.0",
    "prettier": "^3.7.0",
    "source-map-support": "^0.6.0",
    "supertest": "^7.2.0",
    "testcontainers": "^11.1.0",
    "ts-jest": "29.5.0",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.10.0",
    "tsconfig-paths": "4.3.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.40.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
